# Pendle API key — higher rate limits (free tier: 100 CU/min, 200K CU/week)
# Get one at: https://api-v2.pendle.finance/dashboard
PENDLE_API_KEY=

# Swap aggregators (comma-separated). Options: kyberswap, odos, okx, paraswap
# More aggregators = better routing but higher CU cost per call
PENDLE_AGGREGATORS=kyberswap

# Pendle MCP server URL — used by eval suites
# Default: http://api-v2.pendle.finance/core/mcp
# Set to http://localhost:9000/mcp for local testing
PENDLE_MCP_URL=http://api-v2.pendle.finance/core/mcp

# OpenRouter API key — required for running evals with OpenRouter models
OPENROUTER_API_KEY=
