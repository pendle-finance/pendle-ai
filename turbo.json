{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json"],
      "cache": true
    },
    "lint": {
      "inputs": ["src/**", "*.json", "*.ts"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "eval": {
      "inputs": [
        "promptfoo.yaml",
        "../../../packages/plugins/pendle-v2/skills/**/*",
        "../../../evals/scripts/**/*"
      ],
      "outputs": ["results.json"],
      "cache": true
    },
    "validate": {
      "cache": true
    },
    "sync-data": {
      "cache": false
    }
  }
}
